erDiagram
    users ||--o| customers : "is"
    users ||--o| employees : "is"
    categories ||--o{ products : "contains"
    products ||--o{ sales_details : "included_in"
    sales ||--o{ sales_details : "has"
    customers ||--o{ sales : "buys"
    employees ||--o{ sales : "processes"
    products ||--o{ inventory : "registered_in"
    suppliers ||--o{ ingredient_purchases : "supplies"
    customers ||--o{ orders : "places"
    orders ||--o{ order_details : "includes"

    users {
        int user_id PK
        string username
        string email
        string password
        string role
    }

    customers {
        int customer_id PK
        int user_id FK
        string phone
        string address
    }

    employees {
        int employee_id PK
        int user_id FK
        string position
        date hire_date
    }

    products {
        int product_id PK
        int category_id FK
        string name
        string description
        decimal price
    }

    inventory {
        int inventory_id PK
        int product_id FK "unique"
        int stock
        int min_stock
    }

    sales {
        int sale_id PK
        int customer_id FK
        int employee_id FK
        datetime sale_date
        decimal total_amount
        string payment_type
    }

    sales_details {
        int sale_detail_id PK
        int sale_id FK
        int product_id FK
        int quantity
        decimal unit_price
    }

    categories {
        int category_id PK
        string name
    }

    orders {
        int order_id PK
        int customer_id FK
        datetime order_date
        string status
        decimal estimated_total
    }

    order_details {
        int order_detail_id PK
        int order_id FK
        int product_id FK
        int quantity
    }

    suppliers {
        int supplier_id PK
        string name
        string contact_phone
        string email
    }

    ingredient_purchases {
        int purchase_id PK
        int supplier_id FK
        string ingredient_name
        decimal cost
        int quantity
        datetime purchase_date
    }
